<% content_for :title, "Showing user" %>

<div class="mx-auto md:w-2/3 w-full bg-ablescent-white p-5 rounded-lg">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-ablescent-white mb-5 text-elm font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-punch text-4xl">Showing <%= @user.name%>'s profile</h1>

  <div><%= render @user %>

  <%= link_to "Edit this user", edit_user_path(@user), class: "button-primary" %>
  <%= link_to "Back to users", users_path, class: "button-secondary" %>
  <%= button_to "Destroy this user", @user, method: :delete, form_class: "sm:inline-block mt-2 sm:mt-0 sm:ml-2", class: "button-tertiary", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
