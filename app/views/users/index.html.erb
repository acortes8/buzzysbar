<% content_for :title, "Users" %>

<div class="w-full max-w-md mx-auto px-4 sm:px-6 md:max-w-2xl lg:max-w-4xl">
  <% if notice.present? %>
    <p class="notice" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex flex-wrap items-center justify-center sm:justify-between bg-ablescent-white p-3 rounded-xl">
    <h1 class="font-bold text-2xl sm:text-4xl text-punch w-full sm:w-auto text-center sm:text-left">Users</h1>
    <%= link_to "New user", new_user_path, class: "button-primary mt-2 sm:mt-0 sm:ml-4 mx-auto sm:mx-0" %>
  </div>

  <div id="users" class="min-w-full px-5 divide-y divide-gray-200 space-y-5">
    <% if @users.any? %>
      <% @users.each do |user| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render user %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", user, class: "button-primary" %>
            <%= link_to "Edit", edit_user_path(user), class: "button-secondary" %>
            <%= button_to "Destroy", user, method: :delete, class: "button-tertiary", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No users found.</p>
    <% end %>
  </div>
</div>
